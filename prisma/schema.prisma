generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id           String    @id @default(cuid())
  slug         String    @unique
  title        String
  language     String
  genre        String
  mood         String
  vibe         String
  bpm          Int?
  vocalType    String?
  songLength   String?
  variantCount Int       @default(1)
  brief        String?
  status       String    @default("draft")
  folderPath   String
  presetId     String?
  preset       Preset?   @relation(fields: [presetId], references: [id], onDelete: SetNull)
  source       String?
  poemAuthor   String?
  poemTitle    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  variants     Variant[]
  artistIdentity ArtistIdentity?
}

model Variant {
  id             String   @id @default(cuid())
  projectId      String
  label          String
  name           String
  lyricsPath     String?
  sunoPromptPath String?
  negativePrompt String?
  audioPath      String?
  versionName    String?
  status         String   @default("draft")
  sourceType     String   @default("suno") // "suno" | "upload"
  scoreHook      Int?
  scoreVocal     Int?
  scoreBeat      Int?
  scoreEmotion   Int?
  scoreRemix     Int?
  scoreTikTok    Int?
  scoreTotal     Int?
  notes          String?
  createdAt      DateTime @default(now())
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  jobs           Job[]
  tracks         Track[]
}

model Track {
  id             String   @id @default(cuid())
  variantId      String
  index          Int
  audioPath      String
  versionName    String?
  aiScoreHook    Int?
  aiScoreVocal   Int?
  aiScoreBeat    Int?
  aiScoreEmotion Int?
  aiScoreRemix   Int?
  aiScoreTikTok  Int?
  aiScoreTotal   Int?
  aiNotes           String?
  structureJson     String?
  suggestedVersionName String?
  isInstrumental Boolean  @default(false)
  lyricsSource   String?  // "id3" | "ai" | "manual" | null
  srtPath        String?  // relative to project folder, generated by Whisper
  scoreHook      Int?
  scoreVocal     Int?
  scoreBeat      Int?
  scoreEmotion   Int?
  scoreRemix     Int?
  scoreTikTok    Int?
  scoreTotal     Int?
  isApproved     Boolean  @default(false)
  isRejected     Boolean  @default(false)
  notes          String?
  createdAt      DateTime @default(now())
  variant        Variant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  videoJobs      VideoJob[]
}

model Job {
  id          String    @id @default(cuid())
  variantId   String?
  type        String
  status      String    @default("pending")
  attempts    Int       @default(0)
  lastError   String?
  payload     String
  result      String?
  createdAt    DateTime  @default(now())
  processedAt  DateTime?
  nextRetryAt  DateTime?
  variant      Variant?  @relation(fields: [variantId], references: [id])
}

model Preset {
  id              String    @id @default(cuid())
  name            String
  sourceAudioPath String?
  sourceType      String    @default("upload")
  genre           String
  subgenre        String?
  mood            String
  vibe            String?
  energy          String?
  bpm             Int?
  bpmRange        String?
  keySignature    String?
  language        String    @default("instrumental")
  vocalType       String?
  sunoStyle       String
  negativePrompt  String    @default("")
  instruments     String?
  productionStyle String?
  similarArtists  String?
  structureJson   String?
  usageCount      Int       @default(0)
  createdAt       DateTime  @default(now())
  projects        Project[]
}

model VideoJob {
  id             String   @id @default(cuid())
  trackId        String
  track          Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  status         String   @default("queued")
  visualTrack    String   @default("auto")
  outputPath     String?
  youtubeUrl     String?
  youtubeVideoId String?
  errorMessage   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ArtistIdentity {
  id             String   @id @default(cuid())
  projectId      String   @unique
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  colorPrimary   String   @default("#1a1a2e")
  colorAccent    String   @default("#e94560")
  signatureMotif String?
  fontFamily     String   @default("Montserrat")
  visualTrack    String   @default("nature-epic")
  createdAt      DateTime @default(now())
}
