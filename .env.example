# OpenRouter (Fallback für Lyrics/Prompt/Rating-Generierung, falls kein GEMINI_API_KEY gesetzt ist)
# Kostenloser Key: https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_AUDIO_MODEL=google/gemini-2.5-flash   # für Audio-Analyse via OpenRouter (Preset-from-Audio, Rating)

# Gemini (primärer LLM-Provider für Lyrics, Prompts, Cover-Art-Prompt, Audio-Rating/Kritiker)
# Key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_AUDIO_MODEL=gemini-2.5-flash

# Music Provider
# 'mock' = kein API Key nötig, gibt Fake-Audio nach 3s zurück
# 'generic-http' = Suno-kompatibler API-Anbieter über SUNO_PROVIDER_*
# 'sunoapi-org' = https://sunoapi.org (SUNOAPI_ORG_API_KEY)
# 'suno-gcui' = selbstgehostetes gcui-art/suno-api (nur für Status-Anzeige, siehe scripts/proxmox-setup-suno-ct.sh)
MUSIC_PROVIDER=mock
SUNO_PROVIDER_BASE_URL=
SUNO_PROVIDER_API_KEY=
SUNO_PROVIDER_CREATE_ENDPOINT=/api/generate
SUNO_PROVIDER_STATUS_ENDPOINT=/api/status
SUNO_PROVIDER_DOWNLOAD_ENDPOINT=/api/download
SUNOAPI_ORG_API_KEY=
SUNOAPI_ORG_MODEL=V5_5
SUNO_GCUI_URL=

# Stock-Video-B-Roll für die Video-Pipeline
# Pexels: https://www.pexels.com/api/  ·  Pixabay: https://pixabay.com/api/docs/
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Database
# Local dev: SQLite. Proxmox/Docker deploy: Postgres (set per-service in
# docker-compose.yml; see docs/superpowers/specs/2026-06-23-proxmox-nas-migration.md).
DATABASE_URL=file:./prisma/dev.db

# Media storage root (app honors this; NAS mount in production). Empty = repo ./storage.
STORAGE_BASE_PATH=

# Proxmox/Docker deploy only (docker-compose.yml):
# POSTGRES_PASSWORD=
# STORAGE_DIR=/mnt/nas/amf-storage   # NAS bind-mount source

# Telegram (optional, Phase 2 — Freigabe-Workflow für Videos/Uploads)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Whisper (lokale Lyrics-Transkription, offline, kein API-Key nötig)
# Modelle: tiny | base | small | medium (default, ~1.4 GB) | large-v3
# CT100: pip3 install openai-whisper && python3 -c "import whisper; whisper.load_model('medium')"
WHISPER_MODEL=medium
# Timeout in ms — auf langsamen CPUs erhöhen (CT100: 600000)
WHISPER_TIMEOUT=600000

# YouTube (OAuth2 App: https://console.cloud.google.com/apis/credentials, Scopes:
# youtube.upload + youtube.force-ssl, Redirect-URI: <NEXT_PUBLIC_APP_URL>/api/auth/youtube/callback)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_PLAYLIST_ID=          # optional: YouTube playlist ID for auto-add
YOUTUBE_REDIRECT_BASE=        # optional override, z.B. für OAuth via SSH-Tunnel

# External API (headless Projekt-Erstellung, z.B. für Automatisierungs-Agents)
EXTERNAL_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
