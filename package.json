{
  "name": "ai-music-factory",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:worker": "node_modules/.bin/tsx --env-file=.env.local worker/index.ts",
    "dev:telegram": "node_modules/.bin/tsx --env-file=.env.local scripts/telegram-poller.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:worker\" \"npm run dev:telegram\"",
    "build": "next build",
    "start": "next start",
    "start:worker": "node_modules/.bin/tsx worker/index.ts",
    "start:telegram": "node_modules/.bin/tsx scripts/telegram-poller.ts",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@prisma/client": "^5.20.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^173.0.0",
    "hyperframes": "^0.7.14",
    "lucide-react": "^0.454.0",
    "music-metadata": "^11.13.0",
    "next": "^14.2.0",
    "node-id3": "^0.2.9",
    "openai": "^6.44.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^9.0.0",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "prisma": "^5.20.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
